@Обработчик
метод ЗаписатьИЗакрыть()
    ВыполнитьЗаписатьИЗакрыть()
;

@Обработчик
метод ОтметитьВыполненной()
    пер ПрежнееНазвание = Объект.Наименование   
    // Помечаем задачу выполненной — останется только записать…
    пер ЧислоШагов: Число2 = Объект.Шаги.Количество()
    Объект.Важность = ЧислоШагов
    Объект.Выполнена = Истина
    ВыполнитьЗаписать()
;
