    "menus": {
      "commandPalette": [
        {
          "command": "xbsl.docs.open",
          "when": "false"
        },
        {
          "command": "xbsl.formPalette.activate",
          "when": "false"
        },
        {
          "command": "xbsl.properties.showForNode",
          "when": "false"
        }
      ],
      "editor/context": [
        {
          "command": "xbsl.docs.showForSymbol",
          "when": "resourceLangId == xbsl",
          "group": "navigation@9"
        }
      ],
      "editor/title": [
        {
          "command": "xbsl.deploy",
          "when": "resourceLangId == xbsl",
          "group": "navigation"
        },
        {
          "command": "xbsl.previewForm",
          "when": "xbsl.formYaml && resourceLangId == yaml",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "xbsl.project.new",
          "when": "view == xbslMetadata",
          "group": "navigation@0"
        },
        {
          "command": "xbsl.metadata.groupMode",
          "when": "view == xbslMetadata",
          "group": "navigation@1"
        },
        {
          "command": "xbsl.metadata.refresh",
          "when": "view == xbslMetadata",
          "group": "navigation@2"
        },
        {
          "command": "xbsl.metadata.hideEmptyCategories",
          "when": "view == xbslMetadata && !xbsl.metadata.emptyHidden",
          "group": "navigation@3"
        },
        {
          "command": "xbsl.metadata.showEmptyCategories",
          "when": "view == xbslMetadata && xbsl.metadata.emptyHidden",
          "group": "navigation@3"
        },
        {
          "command": "xbsl.docs.search",
          "when": "view == xbslDocs",
          "group": "navigation@1"
        },
        {
          "command": "xbsl.docs.refresh",
          "when": "view == xbslDocs",
          "group": "navigation@2"
        },
        {
          "command": "xbsl.forms.search",
          "when": "view == xbslPalette",
          "group": "navigation@0"
        },
        {
          "command": "xbsl.formPalette.refresh",
          "when": "view == xbslPalette",
          "group": "navigation@1"
        },
        {
          "command": "xbsl.formStructure.insertPreset",
          "when": "view == xbslPalette",
          "group": "1_presets@0"
        },
        {
          "command": "xbsl.formStructure.managePresets",
          "when": "view == xbslPalette",
          "group": "1_presets@1"
        }
      ],
      "view/item/context": [
        {
          "command": "xbsl.metadata.props",
          "when": "view == xbslMetadata && viewItem =~ /\\bprops\\b/",
          "group": "0_props@1"
        },
        {
          "command": "xbsl.metadata.openYaml",
          "when": "view == xbslMetadata && viewItem =~ /\\byaml\\b/",
          "group": "1_open@1"
        },
        {
          "command": "xbsl.metadata.openModule",
          "when": "view == xbslMetadata && viewItem =~ /\\bxbsl\\b/",
          "group": "1_open@2"
        },
        {
          "command": "xbsl.metadata.openObjectModule",
          "when": "view == xbslMetadata && viewItem =~ /\\bobjmod\\b/",
          "group": "1_open@3"
        },
        {
          "command": "xbsl.metadata.previewForm",
          "when": "view == xbslMetadata && viewItem =~ /\\bform\\b/",
          "group": "2_form@1"
        },
        {
          "command": "xbsl.metadata.openAppModule",
          "when": "view == xbslMetadata && viewItem =~ /\\bappmod\\b/",
          "group": "1_open@1"
        },
        {
          "command": "xbsl.metadata.addAttribute",
          "when": "view == xbslMetadata && viewItem =~ /\\baddattr\\b/",
          "group": "inline"
        },
        {
          "command": "xbsl.metadata.addAttribute",
          "when": "view == xbslMetadata && viewItem =~ /\\baddattr\\b/",
          "group": "1_add@1"
        },
        {
          "command": "xbsl.metadata.addDimension",
          "when": "view == xbslMetadata && viewItem =~ /\\badddim\\b/",
          "group": "inline"
        },
        {
          "command": "xbsl.metadata.addDimension",
          "when": "view == xbslMetadata && viewItem =~ /\\badddim\\b/",
          "group": "1_add@1"
        },
        {
          "command": "xbsl.metadata.addResource",
          "when": "view == xbslMetadata && viewItem =~ /\\baddres\\b/",
          "group": "inline"
        },
        {
          "command": "xbsl.metadata.addResource",
          "when": "view == xbslMetadata && viewItem =~ /\\baddres\\b/",
          "group": "1_add@1"
        },
        {
          "command": "xbsl.metadata.addEnumValue",
          "when": "view == xbslMetadata && viewItem =~ /\\baddval\\b/",
          "group": "inline"
        },
        {
          "command": "xbsl.metadata.addEnumValue",
          "when": "view == xbslMetadata && viewItem =~ /\\baddval\\b/",
          "group": "1_add@1"
        },
        {
          "command": "xbsl.metadata.addClientParam",
          "when": "view == xbslMetadata && viewItem =~ /\\baddparam\\b/",
          "group": "inline"
        },
        {
          "command": "xbsl.metadata.addClientParam",
          "when": "view == xbslMetadata && viewItem =~ /\\baddparam\\b/",
          "group": "1_add@1"
        },
        {
          "command": "xbsl.metadata.addStructField",
          "when": "view == xbslMetadata && viewItem =~ /\\baddstructfield\\b/",
          "group": "inline"
        },
        {
          "command": "xbsl.metadata.addStructField",
          "when": "view == xbslMetadata && viewItem =~ /\\baddstructfield\\b/",
          "group": "1_add@1"
        },
        {
          "command": "xbsl.metadata.addTabular",
          "when": "view == xbslMetadata && viewItem =~ /\\baddtabular\\b/",
          "group": "inline"
        },
        {
          "command": "xbsl.metadata.addTabular",
          "when": "view == xbslMetadata && viewItem =~ /\\baddtabular\\b/",
          "group": "1_add@1"
        },
        {
          "command": "xbsl.metadata.addTabularAttr",
          "when": "view == xbslMetadata && viewItem =~ /\\baddtcattr\\b/",
          "group": "inline"
        },
        {
          "command": "xbsl.metadata.addTabularAttr",
          "when": "view == xbslMetadata && viewItem =~ /\\baddtcattr\\b/",
          "group": "1_add@1"
        },
        {
          "command": "xbsl.metadata.addObjectForm",
