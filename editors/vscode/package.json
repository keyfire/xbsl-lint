{
  "name": "xbsl",
  "displayName": "XBSL (1C:Element)",
  "description": "1C:Element (XBSL) tooling: syntax highlighting, linting, navigation, docs and metadata scaffolding via the xbsl engine.",
  "version": "0.30.0",
  "publisher": "keyfire",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "1c",
    "1c-element",
    "xbsl",
    "linter",
    "elemctl",
    "deploy"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/keyfire/xbsl.git",
    "directory": "editors/vscode"
  },
  "homepage": "https://github.com/keyfire/xbsl/tree/main/editors/vscode",
  "bugs": {
    "url": "https://github.com/keyfire/xbsl/issues"
  },
  "galleryBanner": {
    "color": "#0b0b16",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:xbsl",
    "workspaceContains:**/*.xbsl",
    "onView:xbslMetadata",
    "onStartupFinished"
  ],
  "contributes": {
    "languages": [
      {
        "id": "xbsl",
        "aliases": [
          "XBSL",
          "xbsl"
        ],
        "extensions": [
          ".xbsl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "xbsl",
        "scopeName": "source.xbsl",
        "path": "./syntaxes/xbsl.tmLanguage.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "xbslElement",
          "title": "%view.metadataContainer%",
          "icon": "resources/element-tree.svg"
        },
        {
          "id": "xbslDocsContainer",
          "title": "%view.docsContainer%",
          "icon": "resources/docs-book.svg"
        },
        {
          "id": "xbslProps",
          "title": "%view.propsContainer%",
          "icon": "resources/form-props.svg"
        }
      ]
    },
    "views": {
      "xbslElement": [
        {
          "id": "xbslMetadata",
          "name": "%view.metadataTree%",
          "icon": "$(list-tree)",
          "initialSize": 3
        },
        {
          "id": "xbslPalette",
          "name": "%view.formPalette%",
          "icon": "resources/form-palette.svg",
          "when": "xbsl.formDesigner.open",
          "initialSize": 2
        }
      ],
      "xbslDocsContainer": [
        {
          "id": "xbslDocs",
          "name": "%view.docsContainer%",
          "icon": "$(book)"
        }
      ],
      "xbslProps": [
        {
          "id": "xbslProperties",
          "type": "webview",
          "name": "%view.properties%",
          "icon": "resources/form-props.svg"
        }
      ]
    },
    "commands": [
