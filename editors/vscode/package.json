le=dist/blockPresetsCore.test.js --format=cjs --platform=node && node dist/blockPresetsCore.test.js && esbuild test/projectWizardCore.test.ts --bundle --outfile=dist/projectWizardCore.test.js --format=cjs --platform=node && node dist/projectWizardCore.test.js && esbuild test/formDesignerCore.test.ts --bundle --outfile=dist/formDesignerCore.test.js --format=cjs --platform=node && node dist/formDesignerCore.test.js",
