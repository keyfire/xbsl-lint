{
  "name": "xbsl",
  "displayName": "XBSL (1C:Element)",
  "description": "Syntax highlighting and on-the-fly linting for 1C:Element sources (.xbsl) via xbsllint.",
  "version": "0.10.2",
  "publisher": "keyfire",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "1c",
    "1c-element",
    "xbsl",
    "linter",
    "elemctl",
    "deploy"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/keyfire/xbsl-lint.git",
    "directory": "editors/vscode"
  },
  "homepage": "https://github.com/keyfire/xbsl-lint/tree/main/editors/vscode",
  "bugs": {
    "url": "https://github.com/keyfire/xbsl-lint/issues"
  },
  "galleryBanner": {
    "color": "#0b0b16",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:xbsl",
    "workspaceContains:**/*.xbsl"
  ],
  "contributes": {
    "languages": [
      {
        "id": "xbsl",
        "aliases": [
          "XBSL",
          "xbsl"
        ],
        "extensions": [
          ".xbsl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "xbsl",
        "scopeName": "source.xbsl",
        "path": "./syntaxes/xbsl.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "xbsl.lintProject",
        "title": "%cmd.lintProject%",
        "category": "XBSL"
      },
      {
        "command": "xbsl.restartLinter",
        "title": "%cmd.restartLinter%",
        "category": "XBSL"
      },
      {
        "command": "xbsl.choosePalette",
        "title": "%cmd.choosePalette%",
        "category": "XBSL"
      },
      {
        "command": "xbsl.deploy",
        "title": "%cmd.deploy%",
        "category": "XBSL",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "xbsl.previewForm",
        "title": "%cmd.previewForm%",
        "category": "XBSL",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "xbsl.deploy",
          "when": "resourceLangId == xbsl",
          "group": "navigation"
        },
        {
          "command": "xbsl.previewForm",
          "when": "xbsl.formYaml && resourceLangId == yaml",
          "group": "navigation"
        }
      ]
    },
    "configuration": [
      {
        "title": "XBSL",
        "properties": {
          "xbsl.linter.run": {
            "type": "string",
            "enum": [
              "onType",
              "onSave",
              "off"
            ],
            "enumDescriptions": [
              "%config.linter.run.enum.0%",
              "%config.linter.run.enum.1%",
              "%config.linter.run.enum.2%"
            ],
            "default": "onType",
            "scope": "resource",
            "description": "%config.linter.run%"
          },
          "xbsl.linter.command": {
            "type": "string",
            "default": "xbsllint",
            "scope": "resource",
            "description": "%config.linter.command%"
          },
          "xbsl.linter.pythonPath": {
            "type": "string",
            "default": "",
            "scope": "resource",
            "description": "%config.linter.pythonPath%"
          },
          "xbsl.linter.dataDir": {
            "type": "string",
            "default": "",
            "scope": "resource",
            "description": "%config.linter.dataDir%"
          },
          "xbsl.linter.lang": {
            "type": "string",
            "enum": [
              "",
              "ru",
              "en"
            ],
            "enumDescriptions": [
              "%config.linter.lang.enum.0%",
              "%config.linter.lang.enum.1%",
              "%config.linter.lang.enum.2%"
            ],
            "default": "",
            "scope": "resource",
            "description": "%config.linter.lang%"
          },
          "xbsl.linter.select": {
            "type": "string",
            "default": "",
            "scope": "resource",
            "description": "%config.linter.select%"
          },
          "xbsl.linter.ignore": {
            "type": "string",
            "default": "",
            "scope": "resource",
            "description": "%config.linter.ignore%"
          },
          "xbsl.rules": {
            "type": "object",
            "default": {},
            "scope": "resource",
            "additionalProperties": {
              "type": "string",
              "enum": [
                "off",
                "error",
                "warning",
                "info",
                "hint"
              ]
            },
            "markdownDescription": "%config.rules%"
          },
          "xbsl.projectRoot": {
            "type": "string",
            "default": "",
            "scope": "resource",
            "description": "%config.projectRoot%"
          },
          "xbsl.lsp.enabled": {
            "type": "boolean",
            "default": false,
            "scope": "resource",
            "description": "%config.lsp.enabled%"
          },
          "xbsl.lsp.command": {
            "type": "string",
            "default": "",
            "scope": "machine-overridable",
            "description": "%config.lsp.command%"
          },
          "xbsl.linter.debounce": {
            "type": "number",
            "default": 300,
            "minimum": 0,
            "scope": "resource",
            "description": "%config.linter.debounce%"
          },
          "xbsl.workspaceLint": {
            "type": "boolean",
            "default": true,
            "scope": "resource",
            "description": "%config.workspaceLint%"
          },
          "xbsl.workspaceLintTimeout": {
            "type": "number",
            "default": 60000,
            "minimum": 0,
            "scope": "resource",
            "description": "%config.workspaceLintTimeout%"
          },
          "xbsl.navigation.enabled": {
            "type": "boolean",
            "default": true,
            "scope": "resource",
            "description": "%config.navigation.enabled%"
          },
          "xbsl.deploy.elemctlPath": {
            "type": "string",
            "default": "elemctl",
            "scope": "machine-overridable",
            "description": "%config.deploy.elemctlPath%"
          },
          "xbsl.deploy.envFile": {
            "type": "string",
            "default": "",
            "scope": "resource",
            "description": "%config.deploy.envFile%"
          },
          "xbsl.deploy.appId": {
            "type": "string",
            "default": "",
            "scope": "resource",
            "description": "%config.deploy.appId%"
          },
          "xbsl.deploy.extraArgs": {
            "type": "string",
            "default": "",
            "scope": "resource",
            "description": "%config.deploy.extraArgs%"
          }
        }
      },
      {
        "title": "%config.section.groups%",
        "properties": {
          "xbsl.groups.code": {
            "type": "string",
            "enum": [
              "default",
              "error",
              "warning",
              "info",
              "hint",
              "off"
            ],
            "enumDescriptions": [
              "%config.groups.enum.default%",
              "%config.groups.enum.error%",
              "%config.groups.enum.warning%",
              "%config.groups.enum.info%",
              "%config.groups.enum.hint%",
              "%config.groups.enum.off%"
            ],
            "default": "default",
            "scope": "resource",
            "order": 1,
            "description": "%config.groups.code%"
          },
          "xbsl.groups.yaml": {
            "type": "string",
            "enum": [
              "default",
              "error",
              "warning",
              "info",
              "hint",
              "off"
            ],
            "enumDescriptions": [
              "%config.groups.enum.default%",
              "%config.groups.enum.error%",
              "%config.groups.enum.warning%",
              "%config.groups.enum.info%",
              "%config.groups.enum.hint%",
              "%config.groups.enum.off%"
            ],
            "default": "default",
            "scope": "resource",
            "order": 2,
            "description": "%config.groups.yaml%"
          },
          "xbsl.groups.style": {
            "type": "string",
            "enum": [
              "default",
              "error",
              "warning",
              "info",
              "hint",
              "off"
            ],
            "enumDescriptions": [
              "%config.groups.enum.default%",
              "%config.groups.enum.error%",
              "%config.groups.enum.warning%",
              "%config.groups.enum.info%",
              "%config.groups.enum.hint%",
              "%config.groups.enum.off%"
            ],
            "default": "default",
            "scope": "resource",
            "order": 3,
            "description": "%config.groups.style%"
          },
          "xbsl.groups.typography": {
            "type": "string",
            "enum": [
              "default",
              "error",
              "warning",
              "info",
              "hint",
              "off"
            ],
            "enumDescriptions": [
              "%config.groups.enum.default%",
              "%config.groups.enum.error%",
              "%config.groups.enum.warning%",
              "%config.groups.enum.info%",
              "%config.groups.enum.hint%",
              "%config.groups.enum.off%"
            ],
            "default": "default",
            "scope": "resource",
            "order": 4,
            "description": "%config.groups.typography%"
          },
          "xbsl.groups.whitespace": {
            "type": "string",
            "enum": [
              "default",
              "error",
              "warning",
              "info",
              "hint",
              "off"
            ],
            "enumDescriptions": [
              "%config.groups.enum.default%",
              "%config.groups.enum.error%",
              "%config.groups.enum.warning%",
              "%config.groups.enum.info%",
              "%config.groups.enum.hint%",
              "%config.groups.enum.off%"
            ],
            "default": "default",
            "scope": "resource",
            "order": 5,
            "description": "%config.groups.whitespace%"
          },
          "xbsl.groups.encoding": {
            "type": "string",
            "enum": [
              "default",
              "error",
              "warning",
              "info",
              "hint",
              "off"
            ],
            "enumDescriptions": [
              "%config.groups.enum.default%",
              "%config.groups.enum.error%",
              "%config.groups.enum.warning%",
              "%config.groups.enum.info%",
              "%config.groups.enum.hint%",
              "%config.groups.enum.off%"
            ],
            "default": "default",
            "scope": "resource",
            "order": 6,
            "description": "%config.groups.encoding%"
          },
          "xbsl.groups.structure": {
            "type": "string",
            "enum": [
              "default",
              "error",
              "warning",
              "info",
              "hint",
              "off"
            ],
            "enumDescriptions": [
              "%config.groups.enum.default%",
              "%config.groups.enum.error%",
              "%config.groups.enum.warning%",
              "%config.groups.enum.info%",
              "%config.groups.enum.hint%",
              "%config.groups.enum.off%"
            ],
            "default": "default",
            "scope": "resource",
            "order": 7,
            "description": "%config.groups.structure%"
          },
          "xbsl.groups.form": {
            "type": "string",
            "enum": [
              "default",
              "error",
              "warning",
              "info",
              "hint",
              "off"
            ],
            "enumDescriptions": [
              "%config.groups.enum.default%",
              "%config.groups.enum.error%",
              "%config.groups.enum.warning%",
              "%config.groups.enum.info%",
              "%config.groups.enum.hint%",
              "%config.groups.enum.off%"
            ],
            "default": "default",
            "scope": "resource",
            "order": 8,
            "description": "%config.groups.form%"
          },
          "xbsl.groups.query": {
            "type": "string",
            "enum": [
              "default",
              "error",
              "warning",
              "info",
              "hint",
              "off"
            ],
            "enumDescriptions": [
              "%config.groups.enum.default%",
              "%config.groups.enum.error%",
              "%config.groups.enum.warning%",
              "%config.groups.enum.info%",
              "%config.groups.enum.hint%",
              "%config.groups.enum.off%"
            ],
            "default": "default",
            "scope": "resource",
            "order": 9,
            "description": "%config.groups.query%"
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "check": "tsc --noEmit",
    "test": "esbuild test/navCore.test.ts --bundle --outfile=dist/navCore.test.js --format=cjs --platform=node && node dist/navCore.test.js && esbuild test/codeActionsCore.test.ts --bundle --outfile=dist/codeActionsCore.test.js --format=cjs --platform=node && node dist/codeActionsCore.test.js && esbuild test/formPreviewCore.test.ts --bundle --outfile=dist/formPreviewCore.test.js --format=cjs --platform=node && node dist/formPreviewCore.test.js",
    "package": "vsce package --no-dependencies -o xbsl-vscode.vsix",
    "publish:vsce": "vsce publish --no-dependencies",
    "publish:ovsx": "ovsx publish xbsl-vscode.vsix"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3",
    "esbuild": "^0.23",
    "ovsx": "^0.9",
    "typescript": "^5"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "yaml": "^2.9.0"
  },
  "l10n": "./l10n"
}
