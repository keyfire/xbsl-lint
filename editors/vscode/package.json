{
  "name": "xbsl",
  "displayName": "XBSL (1C:Element)",
  "description": "Syntax highlighting and on-the-fly linting for 1C:Element sources (.xbsl) via xbsllint.",
  "version": "0.6.1",
  "publisher": "keyfire",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "1c",
    "1c-element",
    "xbsl",
    "linter"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/keyfire/xbsl-lint.git",
    "directory": "editors/vscode"
  },
  "homepage": "https://github.com/keyfire/xbsl-lint/tree/main/editors/vscode",
  "bugs": {
    "url": "https://github.com/keyfire/xbsl-lint/issues"
  },
  "galleryBanner": {
    "color": "#0b0b16",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:xbsl",
    "workspaceContains:**/*.xbsl"
  ],
  "contributes": {
    "languages": [
      {
        "id": "xbsl",
        "aliases": [
          "XBSL",
          "xbsl"
        ],
        "extensions": [
          ".xbsl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "xbsl",
        "scopeName": "source.xbsl",
        "path": "./syntaxes/xbsl.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "xbsl.lintProject",
        "title": "%cmd.lintProject%",
        "category": "XBSL"
      },
      {
        "command": "xbsl.restartLinter",
        "title": "%cmd.restartLinter%",
        "category": "XBSL"
      },
      {
        "command": "xbsl.choosePalette",
        "title": "%cmd.choosePalette%",
        "category": "XBSL"
      }
    ],
    "configuration": {
      "title": "XBSL",
      "properties": {
        "xbsl.linter.run": {
          "type": "string",
          "enum": [
            "onType",
            "onSave",
            "off"
          ],
          "enumDescriptions": [
            "%config.linter.run.enum.0%",
            "%config.linter.run.enum.1%",
            "%config.linter.run.enum.2%"
          ],
          "default": "onType",
          "scope": "resource",
          "description": "%config.linter.run%"
        },
        "xbsl.linter.command": {
          "type": "string",
          "default": "xbsllint",
          "scope": "resource",
          "description": "%config.linter.command%"
        },
        "xbsl.linter.pythonPath": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "%config.linter.pythonPath%"
        },
        "xbsl.linter.dataDir": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "%config.linter.dataDir%"
        },
        "xbsl.linter.lang": {
          "type": "string",
          "enum": [
            "",
            "ru",
            "en"
          ],
          "enumDescriptions": [
            "%config.linter.lang.enum.0%",
            "%config.linter.lang.enum.1%",
            "%config.linter.lang.enum.2%"
          ],
          "default": "",
          "scope": "resource",
          "description": "%config.linter.lang%"
        },
        "xbsl.linter.select": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "%config.linter.select%"
        },
        "xbsl.linter.ignore": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "%config.linter.ignore%"
        },
        "xbsl.projectRoot": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "%config.projectRoot%"
        },
        "xbsl.lsp.enabled": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "description": "%config.lsp.enabled%"
        },
        "xbsl.lsp.command": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "description": "%config.lsp.command%"
        },
        "xbsl.linter.debounce": {
          "type": "number",
          "default": 300,
          "minimum": 0,
          "scope": "resource",
          "description": "%config.linter.debounce%"
        },
        "xbsl.workspaceLint": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "%config.workspaceLint%"
        },
        "xbsl.workspaceLintTimeout": {
          "type": "number",
          "default": 60000,
          "minimum": 0,
          "scope": "resource",
          "description": "%config.workspaceLintTimeout%"
        },
        "xbsl.navigation.enabled": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "%config.navigation.enabled%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "check": "tsc --noEmit",
    "test": "esbuild test/navCore.test.ts --bundle --outfile=dist/navCore.test.js --format=cjs --platform=node && node dist/navCore.test.js && esbuild test/codeActionsCore.test.ts --bundle --outfile=dist/codeActionsCore.test.js --format=cjs --platform=node && node dist/codeActionsCore.test.js",
    "package": "vsce package --no-dependencies -o xbsl-vscode.vsix",
    "publish:vsce": "vsce publish --no-dependencies",
    "publish:ovsx": "ovsx publish xbsl-vscode.vsix"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3",
    "esbuild": "^0.23",
    "ovsx": "^0.9",
    "typescript": "^5"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "l10n": "./l10n"
}
